# Copy to .env.local for local development.
# Dashboard: Project Settings → API (https://supabase.com/dashboard)

NEXT_PUBLIC_SUPABASE_URL=
NEXT_PUBLIC_SUPABASE_ANON_KEY=

# Canonical URLs for SEO (sitemap, JSON-LD). No trailing slash.
NEXT_PUBLIC_SITE_URL=https://openestatesales.com

# Footer “Source on GitHub” link (optional; defaults to open-source repo).
NEXT_PUBLIC_GITHUB_REPO_URL=https://github.com/msabree/open-estate-sales
